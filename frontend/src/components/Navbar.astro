---
import type { AstroGlobal } from 'astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props as Props;
---

<nav class="bg-canvas border-b border-hairline-soft">
  <div class="container-xl flex items-center justify-between h-14">
    <div class="flex items-center gap-6">
      <a href="/" class="text-heading-md font-bold text-primary hover:no-underline">
        Knowledge Base
      </a>
      <div class="hidden md:flex gap-4">
        <a 
          href="/dashboard" 
          class:list={[
            "text-body-strong transition-colors hover:no-underline",
            currentPath === '/dashboard' ? 'text-primary border-b-2 border-primary' : 'text-mute hover:text-ink'
          ]}
        >
          Dashboard
        </a>
      </div>
    </div>
    
    <div class="flex items-center gap-4">
      <a href="/login" class="text-body-strong text-primary hover:text-charcoal hover:no-underline transition-colors">
        Sign In
      </a>
      <a href="/register" class="btn-primary text-sm">
        Sign Up
      </a>
    </div>
  </div>
</nav>
