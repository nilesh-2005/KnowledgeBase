---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { CollectionsPageWrapper } from '../components/collections/CollectionsPageWrapper';
---

<DashboardLayout title="Collections - Knowledge Base" currentPath="/collections">
  <div class="mb-5 flex flex-col gap-3 border-b border-border pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-xl font-semibold leading-7 text-text-main">Collections</h1>
      <p class="mt-1 text-sm text-text-muted">Manage your personal and team document collections.</p>
    </div>
  </div>

  <CollectionsPageWrapper client:load />
</DashboardLayout>
