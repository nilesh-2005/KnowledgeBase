---
import Layout from '../layouts/Layout.astro';
import { RegisterForm } from '../components/RegisterForm';
---

<Layout title="Sign Up - Knowledge Base" currentPath="/register">
  <div class="min-h-screen flex flex-col items-center justify-center px-4 bg-canvas">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <h1 class="text-heading-xl text-primary mb-2">Create Account</h1>
        <p class="text-body-md text-mute">Join the Knowledge Base community</p>
      </div>

      <div class="bg-soft-cloud rounded-lg p-8">
        <RegisterForm client:only="react" />
      </div>
    </div>
  </div>
</Layout>
