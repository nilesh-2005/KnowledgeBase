---
import Layout from '../layouts/Layout.astro';
import { LoginForm } from '../components/LoginForm';
---

<Layout title="Sign In - Knowledge Base" currentPath="/login">
  <div class="min-h-screen flex flex-col items-center justify-center px-4 bg-canvas">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <h1 class="text-heading-xl text-primary mb-2">Welcome Back</h1>
        <p class="text-body-md text-mute">Sign in to your Knowledge Base account</p>
      </div>

      <div class="bg-soft-cloud rounded-lg p-8">
        <LoginForm client:only="react" />
      </div>
    </div>
  </div>
</Layout>
