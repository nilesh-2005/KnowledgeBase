---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { Badge } from '../components/ui/Badge';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '../components/ui/Card';
import { DashboardStats } from '../components/dashboard/DashboardStats';
import {
  ArrowRight,
  Database,
  FileSearch,
  FileText,
  FolderPlus,
  HardDrive,
  History,
  Plus,
  Share2,
  Tags,
  Upload,
} from 'lucide-react';


const quickActions = [
  {
    title: 'Upload Document',
    description: 'Upload a file to the knowledge base',
    href: '/documents/upload',
    icon: Upload,
  },
  {
    title: 'Create Collection',
    description: 'Organize documents by team or topic',
    href: '/collections',
    icon: FolderPlus,
  },
  {
    title: 'Search Knowledge',
    description: 'Open the workspace search interface',
    href: '/search',
    icon: FileSearch,
  },
];
---

<DashboardLayout title="Dashboard - Knowledge Base" currentPath="/dashboard">
  <div class="mb-5 flex flex-col gap-3 border-b border-border pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <div class="flex items-center gap-2">
        <h1 class="text-xl font-semibold leading-7 text-text-main">Dashboard</h1>
        <Badge variant="secondary">Phase 1</Badge>
      </div>
      <p class="mt-1 text-sm text-text-muted">Workspace overview, activity, and setup shortcuts.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a class="inline-flex h-9 items-center justify-center gap-2 rounded-md border border-border bg-panel px-3 text-sm font-medium text-text-main hover:bg-surface" href="/tags">
        <Tags className="h-4 w-4" />
        Manage Tags
      </a>
      <a class="inline-flex h-9 items-center justify-center gap-2 rounded-md border border-primary bg-primary px-3 text-sm font-medium text-on-primary hover:bg-blue-700" href="/documents">
        <Plus className="h-4 w-4" />
        New Document
      </a>
    </div>
  </div>

  <DashboardStats client:load />

  <div class="mt-5 grid gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-5">
      <Card>
        <CardHeader>
          <div class="flex items-center justify-between gap-3">
            <div>
              <CardTitle>Recent Activity</CardTitle>
              <CardDescription>Actions and updates will appear here as the workspace is used.</CardDescription>
            </div>
            <History className="h-4 w-4 text-text-subtle" />
          </div>
        </CardHeader>
        <CardContent>
          <div class="flex min-h-48 flex-col items-center justify-center rounded-md border border-dashed border-border bg-surface px-6 py-8 text-center">
            <div class="flex h-10 w-10 items-center justify-center rounded-md border border-border bg-panel">
              <History className="h-5 w-5 text-text-muted" />
            </div>
            <h2 class="mt-3 text-sm font-semibold text-text-main">No recent activity</h2>
            <p class="mt-1 max-w-md text-sm text-text-muted">
              Document uploads, tag changes, permission updates, and searches will be listed here once those workflows are active.
            </p>
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle>Workspace Readiness</CardTitle>
          <CardDescription>Current frontend and authentication setup status.</CardDescription>
        </CardHeader>
        <CardContent className="p-0">
          <div class="divide-y divide-border">
            <div class="flex items-center justify-between gap-4 px-4 py-3">
              <div class="min-w-0">
                <p class="text-sm font-medium text-text-main">Authentication</p>
                <p class="text-sm text-text-muted">Login, registration, and protected routing are configured.</p>
              </div>
              <Badge variant="success">Ready</Badge>
            </div>
            <div class="flex items-center justify-between gap-4 px-4 py-3">
              <div class="min-w-0">
                <p class="text-sm font-medium text-text-main">Knowledge workflows</p>
                <p class="text-sm text-text-muted">Document, search, and tagging pages are UI shells for the next phase.</p>
              </div>
              <Badge variant="warning">Pending</Badge>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>

    <aside class="space-y-5">
      <Card>
        <CardHeader>
          <CardTitle>Quick Actions</CardTitle>
          <CardDescription>Common entry points for the workspace.</CardDescription>
        </CardHeader>
        <CardContent className="space-y-2">
          {quickActions.map((action) => {
            const Icon = action.icon;
            return (
              <a
                href={action.href}
                class="group flex items-center justify-between gap-3 rounded-md border border-border bg-panel p-3 text-left hover:bg-surface"
              >
                <span class="flex min-w-0 items-center gap-3">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-border bg-surface">
                    <Icon className="h-4 w-4 text-text-muted" />
                  </span>
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-medium text-text-main">{action.title}</span>
                    <span class="block text-sm leading-5 text-text-muted">{action.description}</span>
                  </span>
                </span>
                <ArrowRight className="h-4 w-4 shrink-0 text-text-subtle group-hover:text-text-main" />
              </a>
            );
          })}
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <div class="flex items-center justify-between gap-3">
            <div>
              <CardTitle>Storage</CardTitle>
              <CardDescription>Usage across uploaded knowledge assets.</CardDescription>
            </div>
            <Database className="h-4 w-4 text-text-subtle" />
          </div>
        </CardHeader>
        <CardContent>
          <div class="flex items-end justify-between gap-3">
            <div>
              <p class="text-2xl font-semibold leading-8 text-text-main">0 MB</p>
              <p class="text-sm text-text-muted">of 5 GB used</p>
            </div>
            <Badge variant="secondary">0%</Badge>
          </div>
          <div class="mt-4 h-2 overflow-hidden rounded-full bg-surface-hover">
            <div class="h-full w-0 rounded-full bg-primary"></div>
          </div>
        </CardContent>
      </Card>
    </aside>
  </div>
</DashboardLayout>
