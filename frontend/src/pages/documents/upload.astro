---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { UploadPageWrapper } from '../../components/documents/UploadPageWrapper';

// Client-side rendering for the upload logic
---

<DashboardLayout title="Upload Document - Knowledge Base" currentPath="/documents/upload">
  <div class="mb-5 flex flex-col gap-3 border-b border-border pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-xl font-semibold leading-7 text-text-main">Upload Document</h1>
      <p class="mt-1 text-sm text-text-muted">Add a new document to the knowledge base.</p>
    </div>
    <a href="/documents" class="inline-flex h-9 items-center justify-center gap-2 rounded-md border border-border bg-panel px-3 text-sm font-medium text-text-main hover:bg-surface">
      Back to Documents
    </a>
  </div>

  <UploadPageWrapper client:load />
</DashboardLayout>
