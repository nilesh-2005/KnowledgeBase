---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const { 
  title = 'Knowledge Base',
  description = 'A comprehensive knowledge base system',
  currentPath = '/',
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-canvas text-text-main font-sans antialiased">
    <div id="error-display" style="position: fixed; top: 0; left: 0; width: 100%; background: red; color: white; z-index: 9999; white-space: pre-wrap; padding: 10px; display: none;"></div>
    <script>
      window.addEventListener('error', (event) => {
        const el = document.getElementById('error-display');
        el.style.display = 'block';
        el.innerText += '\n' + event.message + '\n' + (event.error?.stack || '');
      });
      window.addEventListener('unhandledrejection', (event) => {
        const el = document.getElementById('error-display');
        el.style.display = 'block';
        el.innerText += '\nUnhandled Promise: ' + event.reason;
      });
    </script>
    <header class="flex h-14 w-full items-center border-b border-border bg-panel px-4">
      <div class="mx-auto flex w-full max-w-7xl items-center justify-between">
        <a href="/" class="text-sm font-semibold text-text-main">
          Knowledge Base
        </a>
        <nav class="flex items-center gap-3 text-sm">
          <a class="text-text-muted hover:text-text-main" href="/login">Sign in</a>
          <a class="inline-flex h-8 items-center rounded-md border border-border bg-panel px-3 font-medium text-text-main hover:bg-surface" href="/register">Create account</a>
        </nav>
      </div>
    </header>
    <main class="flex min-h-[calc(100vh-3.5rem)] w-full items-center justify-center bg-canvas px-4 py-10">
      <div class="w-full">
        <slot />
      </div>
    </main>
  </body>
</html>
